{
  "name": "@ahnandev/bidirectional-infinite-scroll",
  "version": "0.1.3",
  "description": "Lightweight bidirectional infinite scroll using scrollIntoView",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahnandev/bidirectional-infinite-scroll.git"
  },
  "homepage": "https://github.com/ahnandev/bidirectional-infinite-scroll#readme",
  "bugs": {
    "url": "https://github.com/ahnandev/bidirectional-infinite-scroll/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:react-matrix": "node ./scripts/verify-react-matrix.mjs",
    "test:react-matrix:demo": "node ./scripts/verify-react-matrix.mjs --demo-build",
    "demo:prepare-react": "node ./scripts/prepare-demo-react-version.mjs",
    "demo:react": "node ./scripts/run-demo-react-version.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "infinite-scroll",
    "bidirectional",
    "scrollIntoView",
    "virtual-scroll",
    "intersection-observer"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
